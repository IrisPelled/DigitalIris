# Frontend (Vite). API base URL; no trailing slash.
# Development: omit to use Vite proxy /api -> http://localhost:3001
# VITE_API_URL=http://localhost:3001

# Optional: per-bot external URLs for "Go to [Bot Name]" after registration.
# JSON object keyed by bot id (e.g. digital-iris, brain-boost-iris).
# VITE_BOT_LINKS={"digital-iris":"https://example.com/iris"}

# Backend (server/.env). Create server/.env from server/.env.example.
# Do not commit real credentials.
